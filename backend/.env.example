# Backend environment configuration for Answer Quality Evaluator
#
# Copy this file to `.env` in the backend directory and fill in values:
#   cp backend/.env.example backend/.env
#
# The FastAPI app loads this file via app/config.py.

# Required: OpenAI API key used for embeddings and LLM calls.
OPENAI_API_KEY=sk-your-key-here

# Optional: embedding model name (defaults to text-embedding-3-small).
EMBEDDING_MODEL=text-embedding-3-small

# Optional: chat/completions model for pipelines and LLM-as-judge.
# If unset, a sensible default is used in code (e.g., gpt-4o-mini).
LLM_MODEL=gpt-4o-mini

# Optional: application log level. One of: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

